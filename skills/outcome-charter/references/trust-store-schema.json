{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Outcome Charter Trust Store",
  "type": "object",
  "required": ["trust_store_version", "keys"],
  "properties": {
    "trust_store_version": { "const": "1.0" },
    "keys": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["issuer", "public_key", "usages", "status", "activated_at"],
        "properties": {
          "issuer": { "type": "string", "minLength": 1 },
          "public_key": { "type": "string", "minLength": 1 },
          "revoked_at": { "type": "string", "format": "date-time" },
          "retired_at": { "type": "string", "format": "date-time" },
          "status": { "enum": ["active", "retired", "revoked"] },
          "activated_at": { "type": "string", "format": "date-time" },
          "usages": {
            "type": "array",
            "minItems": 1,
            "maxItems": 1,
            "uniqueItems": true,
            "items": { "enum": ["capability", "approval", "receipt"] }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
