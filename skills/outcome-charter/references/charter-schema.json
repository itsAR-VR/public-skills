{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Outcome Charter Compatibility Query",
  "type": "object",
  "required": [
    "outcome_class",
    "charter_version",
    "auth_context",
    "auth_validated_at",
    "auth_max_age_seconds",
    "tool_schemas",
    "approval_policy_version",
    "requires_current_approval",
    "required_inputs",
    "required_outputs",
    "runner_contract_version"
    ,"operator_id",
    "approval_scope_digest",
    "preview_digest",
    "action_count"
  ],
  "properties": {
    "outcome_class": { "type": "string", "minLength": 1 },
    "charter_version": { "type": "string", "minLength": 1 },
    "auth_context": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["provider", "principal_id", "tenant_id", "scopes"],
        "properties": {
          "provider": { "type": "string", "minLength": 1 },
          "principal_id": { "type": "string", "minLength": 1 },
          "tenant_id": { "type": "string", "minLength": 1 },
          "scopes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    },
    "auth_validated_at": { "type": "string", "format": "date-time" },
    "auth_max_age_seconds": { "type": "integer", "minimum": 1, "maximum": 3600 },
    "tool_schemas": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["schema_digest", "provider", "required_scopes", "side_effect"],
        "properties": {
          "schema_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
          "provider": { "type": "string", "minLength": 1 },
          "required_scopes": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
          "side_effect": { "enum": ["none", "read", "write", "send", "publish", "delete", "spend", "sign", "deploy"] }
        },
        "additionalProperties": false
      }
    },
    "approval_policy_version": { "type": "string", "minLength": 1 },
    "requires_current_approval": { "type": "boolean" },
    "approval_scope_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "operator_id": { "type": "string", "minLength": 1 },
    "preview_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "action_count": { "type": "integer", "minimum": 0 },
    "required_inputs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "required_outputs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "runner_contract_version": { "type": "string", "minLength": 1 }
    ,
    "attestation": { "$ref": "#/$defs/attestation" }
  },
  "additionalProperties": true,
  "$defs": {
    "attestation": {
      "type": "object",
      "required": ["issuer", "key_id", "issued_at", "expires_at", "nonce", "subject_digest", "signature"],
      "properties": {
        "issuer": { "type": "string", "minLength": 1 },
        "key_id": { "type": "string", "minLength": 1 },
        "issued_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" },
        "nonce": { "type": "string", "minLength": 1, "maxLength": 200 },
        "subject_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "signature": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  }
}
