#!/usr/bin/env bash
# claw-mm — run the claw-code CLI (Rust Claude Code port) with MiniMax M2.7.
# Same token/backend wiring as claude-mm, but dispatches to the claw binary.
# Use this when you want claw specifically; use claude-mm for the full
# Claude Code TUI.
#
# The claw binary path is configurable via CLAW_BIN env var. Default is the
# debug build at ~/Desktop/Codespace/claw-code/rust/target/debug/claw. To
# point at a different build (release, elsewhere), export CLAW_BIN first.

set -euo pipefail

KEY_FILE="${HOME}/.config/minimax/token-plan.key"
CLAW_BIN="${CLAW_BIN:-${HOME}/Desktop/Codespace/claw-code/rust/target/debug/claw}"

if [[ ! -x "$CLAW_BIN" ]]; then
  echo "claw-mm: ${CLAW_BIN} not found or not executable." >&2
  echo "  Build it: cd ~/Desktop/Codespace/claw-code/rust && cargo build --workspace" >&2
  echo "  Or point elsewhere: export CLAW_BIN=/path/to/claw" >&2
  exit 1
fi

if [[ ! -r "$KEY_FILE" ]]; then
  echo "claw-mm: ${KEY_FILE} is missing or unreadable." >&2
  echo "  Create it with your MiniMax Token Plan key:" >&2
  echo "    umask 077 && mkdir -p ~/.config/minimax && printf '%s' '<your-token-plan-key>' > ${KEY_FILE}" >&2
  exit 1
fi

MINIMAX_KEY="$(tr -d '\n\r' < "$KEY_FILE")"
if [[ -z "$MINIMAX_KEY" ]]; then
  echo "claw-mm: ${KEY_FILE} is empty." >&2
  exit 1
fi

export ANTHROPIC_BASE_URL="https://api.minimax.io/anthropic"
export ANTHROPIC_AUTH_TOKEN="$MINIMAX_KEY"
unset ANTHROPIC_API_KEY OPENAI_API_KEY OPENAI_BASE_URL XAI_API_KEY DASHSCOPE_API_KEY
export ANTHROPIC_MODEL="MiniMax-M2.7"

exec "$CLAW_BIN" --model "${CLAW_MM_MODEL:-MiniMax-M2.7}" "$@"
