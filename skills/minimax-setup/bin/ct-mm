#!/usr/bin/env bash
# ct-mm — cmux claude-teams with MiniMax-M2.7 as the backend for every pane.
#
# Spawns multiple parallel claude-code agents (via cmux), each inheriting
# the MiniMax env vars — so every pane talks to api.minimax.io/anthropic
# instead of api.anthropic.com. Flat-rate Token Plan = run a team all day.
#
# Caveat: MiniMax Token Plan enforces a concurrent-request ceiling
# (~5-10 in-flight). Teams of 3-5 agents are safe; larger teams will
# occasionally see 429s when multiple panes fire requests simultaneously.

set -euo pipefail

KEY_FILE="${HOME}/.config/minimax/token-plan.key"
CMUX_BIN="/Applications/cmux.app/Contents/Resources/bin/cmux"

if [[ ! -x "$CMUX_BIN" ]]; then
  echo "ct-mm: cmux not found at ${CMUX_BIN}" >&2
  exit 1
fi

if [[ ! -r "$KEY_FILE" ]]; then
  echo "ct-mm: ${KEY_FILE} is missing or unreadable." >&2
  echo "  Create it once with:" >&2
  echo "    umask 077 && printf '%s' '<your-token-plan-key>' > ${KEY_FILE}" >&2
  exit 1
fi

MINIMAX_KEY="$(tr -d '\n\r' < "$KEY_FILE")"
if [[ -z "$MINIMAX_KEY" ]]; then
  echo "ct-mm: ${KEY_FILE} is empty." >&2
  exit 1
fi

# Route every request through MiniMax's Anthropic-compatible endpoint.
export ANTHROPIC_BASE_URL="https://api.minimax.io/anthropic"
export ANTHROPIC_AUTH_TOKEN="$MINIMAX_KEY"
unset ANTHROPIC_API_KEY

# Pin every Claude Code model slot to MiniMax so subagents, summarization,
# and haiku-fast-path calls don't send unknown model IDs to MiniMax.
export ANTHROPIC_MODEL="MiniMax-M2.7"
export ANTHROPIC_SMALL_FAST_MODEL="MiniMax-M2.7"
export ANTHROPIC_DEFAULT_SONNET_MODEL="MiniMax-M2.7"
export ANTHROPIC_DEFAULT_OPUS_MODEL="MiniMax-M2.7"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="MiniMax-M2.7"

# Profile dir: sessions stay isolated from the main Anthropic profile, but
# claude-mm-sync symlinks shared resources (skills, agents, memories, hooks,
# MCP, settings) so the MiniMax-teams profile leverages your main ~/.claude.
# CLAUDE_CONFIG_DIR_OVERRIDE lets you pin a different profile (e.g. a
# project-scoped one). Auto-sync runs before launch to pick up new skills.
export CLAUDE_CONFIG_DIR="${CLAUDE_CONFIG_DIR_OVERRIDE:-${HOME}/.claude-minimax-teams}"
mkdir -p "$CLAUDE_CONFIG_DIR"
if [[ -z "${CLAUDE_CONFIG_DIR_OVERRIDE:-}" ]] && command -v claude-mm-sync >/dev/null 2>&1; then
  claude-mm-sync teams >/dev/null 2>&1 || true
fi

# Hand off to cmux claude-teams. Your existing `ct` alias uses
# --dangerously-skip-permissions, so we mirror that default but let you
# override by passing your own flags.
exec "$CMUX_BIN" claude-teams --dangerously-skip-permissions "$@"
